# Super-Linter Configuration for GitHub Bootstrap Repository
# This repository uses language-agnostic linters plus YAML/JSON/Markdown for documentation
#
# NOTE: When VALIDATE_* variables are set, super-linter uses "inclusion mode" where ONLY
# the specified linters run. All other linters are automatically disabled.
#
# DESIGN PRINCIPLE: One linter per file type to avoid conflicts and keep runs fast.
# - JSON  → VALIDATE_JSON_PRETTIER only (prettier validates + formats; no separate jsonlint)
# - YAML  → VALIDATE_YAML_PRETTIER only (prettier validates + formats)
# - Markdown → VALIDATE_MARKDOWN only (markdownlint rules; prettier auto-fixes via FIX_MARKDOWN_PRETTIER)
# - Shell → shellcheck (correctness) + shfmt (formatting) — complementary, not overlapping

# ===== ENABLED LINTERS =====
# Code correctness and style
VALIDATE_EDITORCONFIG=true
VALIDATE_BASH=true
VALIDATE_BASH_EXEC=true
VALIDATE_SHELL_SHFMT=true

# Documentation and config formatting (one tool per file type)
VALIDATE_MARKDOWN=true
VALIDATE_YAML_PRETTIER=true
VALIDATE_JSON_PRETTIER=true
VALIDATE_XML=true
VALIDATE_NATURAL_LANGUAGE=true

# Git hygiene
VALIDATE_GIT_MERGE_CONFLICT_MARKERS=true
VALIDATE_GIT_COMMITLINT=true

# Hooks
VALIDATE_PRE_COMMIT=true

# Terraform formatting (validates terraform fmt compliance for files in terraform/)
VALIDATE_TERRAFORM_FMT=true

# ===== AUTO-FIX SETTINGS =====
# Used by 'make lint-fix' to automatically fix formatting issues.
# Only effective when the volume is mounted read-write (not :ro).
FIX_YAML_PRETTIER=true
FIX_MARKDOWN_PRETTIER=true
FIX_JSON_PRETTIER=true
FIX_SHELL_SHFMT=true
FIX_TERRAFORM_FMT=true